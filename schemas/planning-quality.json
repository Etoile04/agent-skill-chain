{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PlanningQualityRecord",
  "type": "object",
  "required": ["plan_id", "task_type", "total_steps", "steps_completed", "steps_failed", "fallbacks_triggered", "total_time_ms"],
  "properties": {
    "plan_id": {"type": "string"},
    "task_type": {"type": "string"},
    "total_steps": {"type": "integer", "minimum": 1},
    "steps_completed": {"type": "integer", "minimum": 0},
    "steps_failed": {"type": "integer", "minimum": 0},
    "fallbacks_triggered": {"type": "integer", "minimum": 0},
    "total_time_ms": {"type": "number", "minimum": 0},
    "hint_violations": {"type": "integer", "minimum": 0},
    "tests_total": {"type": "integer"},
    "tests_passed": {"type": "integer"},
    "timestamp": {"type": "string", "format": "date-time"}
  }
}
